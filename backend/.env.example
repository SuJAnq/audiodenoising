ALLOWED_ORIGINS=https://your-frontend-domain.example.com,http://localhost:3000
MAX_DURATION_SEC=325
CHECKPOINT_DIR=/app/checkpoints
# Optional: point directly to a file or directory containing .pt checkpoints
# MODEL_PATH=/app/checkpoints/unet_best.pt
# MODEL_PATH=/app/backend/models/unet_best.pt

# Optional residual-noise post-filter controls
APPLY_POSTFILTER=true
APPLY_SPECTRAL_GATE=true
SPECTRAL_GATE_THRESHOLD=1.5
APPLY_WIENER_POSTFILTER=true
WIENER_BETA=0.02
POSTFILTER_CUTOFF_HZ=6500
POSTFILTER_STRENGTH=0.35
